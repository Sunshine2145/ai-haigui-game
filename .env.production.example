# 生产环境配置文件
# 复制此文件为 .env.production 并填写实际值

# DeepSeek API 密钥 (后端使用)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 后端服务基础URL (前端使用)
# 例如：https://ai-haigui-game-production-996c.up.railway.app
VITE_BACKEND_API_BASE_URL=https://your-backend-service-url.com

# 以下变量前端可能不需要，但保留以供参考
VITE_AI_API_KEY=sk-example-key
VITE_AI_API_BASE_URL=https://api.deepseek.com/v1/chat/completions